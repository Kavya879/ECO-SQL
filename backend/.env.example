# PostgreSQL Connection
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=postgres

# Server
PORT=3001
CORS_ORIGIN=http://localhost:5173

# --- Hardware & Carbon Model Overrides (all optional) ---
# Auto-detected defaults are used for any variable left unset.
# See backend/services/hardwareDetector.js for exact fallback logic.

# Power Usage Effectiveness (1.0-3.0). Overrides INFRASTRUCTURE-based estimate below.
# PUE=1.3

# Shortcut for PUE: "cloud" -> 1.15, anything else -> 1.3 (on-prem/laptop default)
# INFRASTRUCTURE=cloud

# Total embodied carbon of the host hardware, in gCO2eq. Overrides HARDWARE_TYPE below.
# EMBODIED_CARBON=150000

# Shortcut for EMBODIED_CARBON: "server" -> 200000, "laptop" -> 75000, else -> 100000 (desktop)
# HARDWARE_TYPE=desktop

# Fraction of total system resources reserved for a single query (0-1)
# RESERVED_RATIO=0.05

# Expected total operating hours of the hardware over its lifetime
# TOTAL_OPERATING_HOURS=11000

# Grid carbon intensity in gCO2eq/kWh (global avg ~475; India ~442, US ~386, EU ~233, France ~45)
# GRID_CARBON_INTENSITY=475

# CPU utilization during query execution (0-1)
# CPU_UTILIZATION=0.5
